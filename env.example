# ============================================================
# Moto Central — Variables de entorno (Evolution API)
# Copia este archivo como .env y completa los valores
# NUNCA subas el .env real a Git
# ============================================================

# ── Base de datos ─────────────────────────────────────────────
DB_HOST=localhost
DB_USERNAME=moto_user
DB_PASSWORD=tu_password_aqui
MYSQL_DATABASE=moto_central
MYSQL_ROOT_PASSWORD=tu_root_password_aqui
DB_PORT=3306
TIME_ZONE=America/Bogota

# ── Evolution API ─────────────────────────────────────────────
# URL de tu instancia de Evolution API (en Railway o VPS)
EVOLUTION_API_URL=https://tu-evolution-api.up.railway.app
# Nombre de la instancia que creaste en Evolution API
EVOLUTION_INSTANCE=motooo
# API Key que configuraste en Evolution API
EVOLUTION_API_KEY=tu_api_key_aqui

# ── Admin ─────────────────────────────────────────────────────
ADMIN_WHATSAPP=+573001234567
ADMIN_NOMBRE=Admin Principal

# ── Bot ───────────────────────────────────────────────────────
TIMEOUT_SERVICIO_MIN=15
PORT=3000
NODE_ENV=production
